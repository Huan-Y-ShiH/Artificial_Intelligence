.page {
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #5aaf4f;
  margin-bottom: 12rpx;
}

.hero-sub {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.hero-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #888;
  line-height: 1.45;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
}

.sec-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #f0f0f0;
  color: #555;
}

.tag.on {
  background: #87b75f;
  color: #fff;
}

.meal-row {
  display: flex;
  gap: 16rpx;
}

.meal-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  background: #f0f0f0;
  color: #666;
  font-weight: 600;
}

.meal-btn.on {
  background: #5aaf4f;
  color: #fff;
}

.btn-primary {
  background: #5aaf4f !important;
  color: #fff !important;
  border-radius: 999rpx !important;
  font-size: 28rpx !important;
  font-weight: 600;
  border: none !important;
}

.btn-primary.full {
  width: 100%;
}

.search {
  margin-bottom: 24rpx;
}

.loading-box {
  text-align: center;
  padding: 48rpx 0 32rpx;
}

.bag {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.loading-txt {
  font-size: 26rpx;
  color: #888;
}

.meal-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #eef2ee;
}

.meal-name {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #5aaf4f;
  margin-bottom: 8rpx;
}

.meal-desc {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 20rpx;
  line-height: 1.45;
}

.nut-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.nut-cell {
  width: calc(50% - 6rpx);
  background: #f8faf7;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  box-sizing: border-box;
}

.nk {
  display: block;
  font-size: 20rpx;
  color: #888;
}

.nv {
  font-size: 26rpx;
  font-weight: 700;
  color: #5aaf4f;
}

.reason-box {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx;
}

.rk {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.rv {
  font-size: 24rpx;
  color: #555;
  line-height: 1.55;
}

.btn-shuffle {
  width: 100%;
  margin-bottom: 24rpx;
  background: #c5e86c !important;
  color: #3d5c00 !important;
  font-weight: 700 !important;
  border-radius: 999rpx !important;
  border: none !important;
  font-size: 28rpx !important;
}

.tip {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.bottom-spacer {
  height: 48rpx;
}
