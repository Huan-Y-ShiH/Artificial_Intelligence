/* 整体容器 */
.container {
    background-color: #f5f5f5;
    min-height: 100vh;
    padding: 20px;
    box-sizing: border-box;
  }
  
  /* 操作按钮区域 */
  .add-buttons {
    display: flex;
    justify-content: space-around;
    margin-bottom: 20px;
  }
  .add-buttons button {
    background-color: #1AAD19;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 10px 15px;
    font-size: 16px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }
  
  /* 今日总结 */
  .today-summary {
    text-align: center;
    margin-bottom: 20px;
  }
  .today-summary text {
    display: block;
    font-size: 16px;
    color: #333;
  }
  
  /* 记录列表 */
  .record-list {
    background-color: #fff;
    border-radius: 8px;
    padding: 15px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    margin-bottom: 20px;
  }
  .record-item {
    border-bottom: 1px solid #eee;
    padding: 10px 0;
  }
  .record-item:last-child {
    border-bottom: none;
  }
  .record-item text {
    display: block;
  }
  .record-item .small {
    font-size: 14px;
    color: #888;
  }
  
  /* 饮水区域 */
  .water-section {
    display: flex;
    justify-content: space-around;
  }
  .water-section button {
    background-color: #1AAD19;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 16px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }
  .water-section button.gray {
    background-color: #ccc;
    color: #333;
  }
  