.page {
  min-height: 100vh;
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
}

.health-tip {
  background: linear-gradient(135deg, #fff9e6, #fff3cc);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f5e6b8;
}

.tip-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #b8860b;
  margin-bottom: 8rpx;
}

.tip-body {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}

.food-card .card-head,
.water-card .card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5aaf4f;
}

.card-emoji {
  font-size: 40rpx;
}

.field-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.field-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  background: #f7f8f6;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.mode-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.mode-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  background: #eef5eb;
  color: #555;
  border: 2rpx solid transparent;
}

.mode-btn.alt {
  background: #e8f2ff;
}

.mode-btn.on {
  background: #5aaf4f;
  color: #fff;
  border-color: #4a9942;
}

.mode-btn.alt.on {
  background: #3d8fd8;
  border-color: #2f7abf;
}

.upload-zone {
  border: 2rpx dashed #cfd8cc;
  border-radius: 20rpx;
  padding: 48rpx 24rpx;
  text-align: center;
  background: #fafbf9;
  margin-bottom: 8rpx;
}

.upload-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.upload-main {
  display: block;
  font-size: 28rpx;
  color: #5aaf4f;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.upload-sub {
  font-size: 22rpx;
  color: #999;
}

.btn-primary {
  background: #5aaf4f !important;
  color: #fff !important;
  border-radius: 999rpx !important;
  font-size: 28rpx !important;
  font-weight: 600;
  border: none !important;
}

.btn-primary.full {
  width: 100%;
}

.btn-primary.flex1 {
  flex: 1;
}

.btn-secondary {
  background: #f0f0f0 !important;
  color: #333 !important;
  border-radius: 999rpx !important;
  font-size: 26rpx !important;
  border: none !important;
}

.btn-ghost {
  margin-top: 16rpx;
  background: transparent !important;
  color: #5aaf4f !important;
  font-size: 26rpx !important;
  border: 1rpx solid #5aaf4f !important;
  border-radius: 999rpx !important;
}

.btn-ghost.full {
  width: 100%;
}

.mini-top {
  margin-top: 12rpx;
}

.pending {
  margin-top: 28rpx;
  padding: 24rpx;
  background: #f8faf7;
  border-radius: 20rpx;
  border: 1rpx solid #e0ebe0;
}

.pending-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  color: #333;
}

.pending-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #555;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #eee;
}

.pending-row:last-of-type {
  border-bottom: none;
}

.pending-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.mini-strip {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.row-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #5aaf4f;
}

.row-gap {
  margin-top: 28rpx;
}

.row-num {
  font-size: 26rpx;
  color: #333;
  margin: 12rpx 0 16rpx;
}

.progress-track {
  height: 16rpx;
  background: #ececec;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.25s ease;
}

.progress-fill.cal {
  background: linear-gradient(90deg, #5aaf4f, #7bc96f);
}

.progress-fill.water {
  background: linear-gradient(90deg, #4a9eff, #6bb8ff);
}

.preset-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.preset {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  background: #e8f4ff;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2a7abf;
}

.water-add {
  margin-top: 8rpx;
}

.btn-text {
  margin-top: 20rpx;
  background: transparent !important;
  color: #999 !important;
  font-size: 24rpx !important;
  border: none !important;
}

.summary-card {
  background: linear-gradient(160deg, #fff, #f3faf2);
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(90, 175, 79, 0.12);
  border: 1rpx solid #e0f0dc;
}

.summary-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.summary-val {
  font-size: 72rpx;
  font-weight: 800;
  color: #5aaf4f;
  line-height: 1.1;
}

.summary-unit {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.food-line {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.food-line:last-child {
  border-bottom: none;
}

.food-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.food-meta {
  font-size: 22rpx;
  color: #888;
  margin-top: 6rpx;
}

.bottom-spacer {
  height: 40rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.modal-box {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 48rpx 40rpx 36rpx;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.12);
}

.modal-title {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-desc {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  line-height: 1.55;
  margin-bottom: 36rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.modal-actions.vertical {
  flex-direction: column;
  align-items: stretch;
}

.modal-btn {
  flex: 1;
  font-size: 28rpx;
  border-radius: 999rpx !important;
  border: none !important;
  padding: 20rpx 0 !important;
}

.modal-btn.ghost {
  background: #f5f5f5 !important;
  color: #666 !important;
}

.modal-btn.primary {
  background: #5aaf4f !important;
  color: #fff !important;
}

.modal-btn.full {
  width: 100%;
}

.modal-btn.link {
  background: transparent !important;
  color: #888 !important;
  font-size: 26rpx !important;
}

.modal-dev {
  margin-top: 24rpx;
  font-size: 24rpx !important;
  color: #5aaf4f !important;
  background: #f5faf4 !important;
  border: 1rpx dashed #5aaf4f !important;
  border-radius: 16rpx !important;
}
