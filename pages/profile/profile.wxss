/* pages/profile/profile.wxss *//* 页面整体背景及容器 */
page, .container {
    background-color: #f5f5f5;
    min-height: 100vh;
    padding: 20px;
    box-sizing: border-box;
  }
  
  /* 每个信息块卡片样式 */
  .section {
    background-color: #fff;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 15px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  
  /* 标签样式 */
  .section text:first-child {
    display: block;
    font-size: 16px;
    font-weight: bold;
    color: #333;
    margin-bottom: 8px;
  }
  
  /* input 输入框样式 */
  input {
    width: 100%;
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 8px;
    font-size: 16px;
    color: #333;
    box-sizing: border-box;
  }
  
  /* picker 选择器样式 */
  .picker {
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 8px;
    font-size: 16px;
    color: #666;
    background-color: #fff;
    box-sizing: border-box;
  }
  
  /* radio-group 样式，内置项水平排列 */
  radio-group {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }
  radio-group label {
    display: flex;
    align-items: center;
    margin-right: 20rpx;
    margin-bottom: 5px;
  }
  radio-group radio {
    margin-right: 5px;
  }
  
  /* 保存按钮样式 */
  button {
    width: 100%;
    background-color: #1AAD19;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 12px;
    font-size: 18px;
    margin-top: 10px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }
  