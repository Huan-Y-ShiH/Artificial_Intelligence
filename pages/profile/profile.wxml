<scroll-view
  class="page safe-page {{tabBarHidden ? 'safe-page--compact' : ''}}"
  style="height: {{scrollViewHeight}}px;"
  scroll-y="{{true}}"
  bindscroll="onTabPageScroll"
  bindscrolltoupper="onTabPageScrollToUpper"
  upper-threshold="50"
>
  <view class="header-card">
    <image
      class="avatar"
      src="{{userInfo.avatarUrl || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3EaOiasW7vbMgoDBpRKhGBPJw/0'}}"
      mode="aspectFill"
    />
    <view class="header-text">
      <text class="nick">{{userInfo.nickName || '微信用户'}}</text>
      <text class="sub">个人健康档案 · 数据仅保存在本机</text>
    </view>
  </view>

  <view class="card">
    <view class="card-head">
      <text class="card-title">基本信息</text>
      <text class="card-tip">填写后点底部保存</text>
    </view>
    <view class="row">
      <text class="label">年龄</text>
      <input
        class="inp"
        type="number"
        value="{{profile.age}}"
        placeholder="岁"
        data-f="age"
        bindinput="onProfileFieldInput"
      />
    </view>
    <view class="row">
      <text class="label">性别</text>
      <radio-group class="rg" value="{{profile.gender}}" bindchange="onGenderChange">
        <label class="lb"><radio value="男" color="#5aaf4f" />男</label>
        <label class="lb"><radio value="女" color="#5aaf4f" />女</label>
      </radio-group>
    </view>
    <view class="row">
      <text class="label">身高(cm)</text>
      <input
        class="inp"
        type="digit"
        value="{{profile.height}}"
        placeholder="如 165"
        data-f="height"
        bindinput="onProfileFieldInput"
      />
    </view>
    <view class="row">
      <text class="label">体重(kg)</text>
      <input
        class="inp"
        type="digit"
        value="{{profile.weight}}"
        placeholder="如 55"
        data-f="weight"
        bindinput="onProfileFieldInput"
      />
    </view>
    <view class="row">
      <text class="label">目标体重(kg)</text>
      <input
        class="inp"
        type="digit"
        value="{{profile.targetWeight}}"
        bindinput="onTargetWeightInput"
        placeholder="可选，不填则按目标推算"
      />
    </view>
    <view class="row">
      <text class="label">运动频率</text>
      <picker mode="selector" range="{{exerciseOptions}}" bindchange="onExerciseChange">
        <view class="picker-val">{{profile.exerciseFreq || '请选择'}}</view>
      </picker>
    </view>
  </view>

  <view class="card bmi-card">
    <text class="card-title">BMI 指数</text>
    <view class="bmi-row">
      <text class="bmi-num">{{bmiText}}</text>
      <text class="bmi-badge" wx:if="{{bmiBadge}}">{{bmiBadge}}</text>
    </view>
    <text class="bmi-advice">{{bmiAdvice}}</text>
  </view>

  <view class="card">
    <text class="card-title">健康目标</text>
    <view class="goal-grid">
      <view
        wx:for="{{goalOptions}}"
        wx:key="key"
        class="goal-item {{profile.goal === item.key ? 'on' : ''}}"
        data-goal="{{item.key}}"
        bindtap="selectGoal"
      >
        <text class="g-emoji">{{item.emoji}}</text>
        <text class="g-title">{{item.title}}</text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{trendBars.length}}">
    <text class="card-title">预期体重变化趋势</text>
    <view class="trend-chart">
      <view class="trend-col" wx:for="{{trendBars}}" wx:key="label">
        <view class="trend-bar-wrap">
          <view class="trend-bar" style="height: {{item.h}}%;"></view>
        </view>
        <text class="trend-val">{{item.val}}kg</text>
        <text class="trend-lb">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <text class="card-title">饮食偏好（影响推荐）</text>
    <view class="switch-row" bindtap="toggleVege">
      <text>素食优先</text>
      <text class="sw {{profile.vegetarian ? 'on' : ''}}">{{profile.vegetarian ? '已开启' : '关闭'}}</text>
    </view>
    <view class="switch-row" bindtap="toggleLactose">
      <text>无乳糖 / 少乳制品</text>
      <text class="sw {{profile.lactoseFree ? 'on' : ''}}">{{profile.lactoseFree ? '已开启' : '关闭'}}</text>
    </view>
  </view>

  <button class="btn-save" bindtap="saveProfile">保存资料</button>
  <view class="bottom-spacer"></view>
</scroll-view>

<ai-assistant tab-bar-hidden="{{tabBarHidden}}" />
