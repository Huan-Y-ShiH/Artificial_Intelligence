/** 全局主题与全面屏安全区（红米等 Android 挖孔/手势条） */
page {
  background-color: #f5f6f4;
  color: #333;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 自定义 TabBar：min-height 100rpx + padding + 图标/文字 + 与内容留白；与 Tab 内 safe-area 叠加留足余量 */
.safe-page {
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(200rpx + constant(safe-area-inset-bottom));
}

/* Tab 上滑隐藏后：仅保留安全区 + 少量边距 */
.safe-page--compact {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
}

/*
 * scroll-view 若用 min-height:100vh 会随内容撑开，内部不滚动，bindscroll 不触发。
 * 固定 height 后取消 min-height，由 JS 写入 scrollViewHeight（windowHeight）。
 */
scroll-view.page.safe-page {
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
}
