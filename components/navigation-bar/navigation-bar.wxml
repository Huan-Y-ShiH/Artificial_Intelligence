<view class="nav-bar">
  <!-- 左侧图标（可选） -->
  <view class="left" wx:if="{{showLeftIcon}}" bindtap="onLeftTap">
    <image src="{{leftIcon}}" class="icon"></image>
  </view>
  <!-- 中间标题 -->
  <view class="title">
    <text>{{title}}</text>
  </view>
  <!-- 右侧图标（可选） -->
  <view class="right" wx:if="{{showRightIcon}}" bindtap="onRightTap">
    <image src="{{rightIcon}}" class="icon"></image>
  </view>
</view>
